#!/bin/bash
# Script to run Prettier on changed files
# Usage:
#   - As Claude Code hook: receives JSON via STDIN
#   - Direct invocation: prettier_changed_files [-v|--verbose] [file1 file2 ...]
#
# Provides informative feedback by showing a unified diff of formatting changes.
# Uses Prettier's stdout output (default behavior) to compare against originals,
# following the design principle that auto-fix scripts should show what was corrected.
#
# See ../../docs/hook_interface.md for interface specification and exit code behavior

set -e
HOOK_NAME="prettier"
FILE_PATTERN='\.(js|jsx|ts|tsx|json|css|scss|less|md|markdown|html|yml|yaml)$'
SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPTS_DIR/hook_common.bash"

# Source nvm if available (needed for hooks which run in fresh shell)
# Deferred until after extension check to avoid ~100ms cost on non-matching files
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  # shellcheck source=/dev/null
  source "$NVM_DIR/nvm.sh" --no-use
  if [ -f ".nvmrc" ]; then
    nvm use --silent 2>/dev/null || true
  fi
fi

# Determine Prettier command - prefer prettierd (daemon, ~0.04s warm) over cold prettier (~0.3s)
# To disable prettierd: set NO_PRETTIERD=1 or touch ./tmp/no-prettierd
# To suppress the "not installed" hint: touch ./tmp/no-prettierd
USE_PRETTIERD=false
if command -v prettierd &> /dev/null && [ -z "$NO_PRETTIERD" ] && [ ! -f "./tmp/no-prettierd" ]; then
  USE_PRETTIERD=true
elif [ -f "node_modules/.bin/prettier" ]; then
  PRETTIER_CMD="./node_modules/.bin/prettier"
  if ! command -v prettierd &> /dev/null && [ ! -f "./tmp/no-prettierd" ]; then
    echo "prettierd is not installed. Install it to speed up formatting: npm install -g @fsouza/prettierd (touch ./tmp/no-prettierd to suppress)" >&2
  fi
else
  PRETTIER_CMD="npx --silent prettier"
fi

if [ "$VERBOSE" = true ]; then
  echo "Changed files detected:"
  echo "  $CHANGED_FILES"
  echo ""
  echo "Running Prettier with auto-format..."
  echo ""
fi

# Format a file with prettierd (stdin/stdout) and write in-place if changed.
# Returns 0 if successful (whether or not changes were made), 1 on error.
# Sets CHANGES_DETECTED=true and appends to DIFF_OUTPUT if file was reformatted.
prettierd_format_file() {
  local file="$1"
  local formatted
  formatted=$(mktemp)

  if ! prettierd "$file" < "$file" > "$formatted" 2>&1; then
    echo "Prettier error on $file:" >&2
    cat "$formatted" >&2
    rm "$formatted"
    return 1
  fi

  if ! diff -q "$file" "$formatted" > /dev/null 2>&1; then
    CHANGES_DETECTED=true
    local file_diff
    file_diff=$(diff -U1 "$file" "$formatted" | tail -n +3 || true)
    DIFF_OUTPUT="${DIFF_OUTPUT}${file}\n${file_diff}\n\n"
    mv "$formatted" "$file"
  else
    rm "$formatted"
  fi
  return 0
}

# Format a file with prettier CLI and write in-place if changed.
prettier_format_file() {
  local file="$1"
  local formatted
  formatted=$(mktemp)

  if ! $PRETTIER_CMD "$file" > "$formatted" 2>&1; then
    echo "Prettier error on $file:" >&2
    cat "$formatted" >&2
    rm "$formatted"
    return 1
  fi

  if ! diff -q "$file" "$formatted" > /dev/null 2>&1; then
    CHANGES_DETECTED=true
    local file_diff
    file_diff=$(diff -U1 "$file" "$formatted" | tail -n +3 || true)
    DIFF_OUTPUT="${DIFF_OUTPUT}${file}\n${file_diff}\n\n"
    $PRETTIER_CMD --write "$file" > /dev/null 2>&1
  fi

  rm "$formatted"
  return 0
}

set +e

CHANGES_DETECTED=false
DIFF_OUTPUT=""
HAD_ERRORS=false

for file in $CHANGED_FILES; do
  if [ -f "$file" ]; then
    if [ "$USE_PRETTIERD" = true ]; then
      prettierd_format_file "$file" || HAD_ERRORS=true
    else
      prettier_format_file "$file" || HAD_ERRORS=true
    fi
  fi
done

set -e

if [ "$HAD_ERRORS" = true ]; then
  hook_status fail
fi

if [ "$CHANGES_DETECTED" = true ]; then
  echo "Prettier reformatted:"
  echo ""
  echo -e "$DIFF_OUTPUT"
fi

hook_status pass
