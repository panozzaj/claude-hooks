#!/bin/bash
# Script to run cargo fmt on changed Rust files
# Usage:
#   - As Claude Code hook: receives JSON via STDIN
#   - Direct invocation: cargo_fmt_changed_files [-v|--verbose] [file1 file2 ...]
#
# See ../../docs/hook_interface.md for interface specification and exit code behavior

set -e
HOOK_NAME="cargo fmt"
FILE_PATTERN='\.rs$'
SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPTS_DIR/hook_common.bash"

# Find the Cargo.toml directory (walk up from the file)
find_cargo_root() {
  local dir="$1"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/Cargo.toml" ]; then
      echo "$dir"
      return 0
    fi
    dir=$(dirname "$dir")
  done
  return 1
}

FIRST_FILE=$(echo "$CHANGED_FILES" | awk '{print $1}')
if [ -f "$FIRST_FILE" ]; then
  FILE_DIR=$(dirname "$FIRST_FILE")
else
  FILE_DIR="."
fi

CARGO_ROOT=$(find_cargo_root "$(cd "$FILE_DIR" && pwd)" || true)

if [ -z "$CARGO_ROOT" ]; then
  hook_status na "no Cargo.toml found"
fi

if [ "$VERBOSE" = true ]; then
  echo "Changed Rust files detected:"
  echo "  $CHANGED_FILES"
  echo ""
  echo "Running cargo fmt in $CARGO_ROOT..."
  echo ""
fi

# Run cargo fmt
FMT_OUTPUT=$(mktemp)

set +e
(cd "$CARGO_ROOT" && cargo fmt 2>&1) > "$FMT_OUTPUT"
FMT_STATUS=$?
set -e

if [ $FMT_STATUS -eq 0 ]; then
  if [ -s "$FMT_OUTPUT" ]; then
    cat "$FMT_OUTPUT"
    echo ""
  fi
  rm "$FMT_OUTPUT"
  hook_status pass
else
  cat "$FMT_OUTPUT" >&2
  echo "" >&2
  rm "$FMT_OUTPUT"
  hook_status fail
fi
