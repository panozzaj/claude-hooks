#!/bin/bash
# shellcheck source-path=SCRIPTDIR
# Run ShellCheck on changed shell script files
# Usage:
#   - As Claude Code hook: receives JSON via STDIN
#   - Direct invocation: shellcheck_changed_files [-v|--verbose] [file1 file2 ...]
#
# See ../../docs/hook_interface.md for interface specification and exit code behavior

set -e
HOOK_NAME="shellcheck"
# Accept all files, then filter to shell scripts by extension or shebang below
FILE_PATTERN='.'
SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPTS_DIR/hook_common.bash"

# Filter to only shell script files
SHELL_FILES=()
for file in $CHANGED_FILES; do
  # Skip if file doesn't exist
  [ -f "$file" ] || continue

  # Check by extension
  if [[ "$file" =~ \.(sh|bash)$ ]]; then
    SHELL_FILES+=("$file")
    continue
  fi

  # Check for shell shebang (bash, sh, zsh)
  if head -1 "$file" 2>/dev/null | grep -qE '^#!.*\b(bash|sh|zsh)\b'; then
    SHELL_FILES+=("$file")
  fi
done

if [ ${#SHELL_FILES[@]} -eq 0 ]; then
  hook_status na
fi

# Check that shellcheck is available
if ! command -v shellcheck &> /dev/null; then
  hook_status na "not installed"
fi

if [ "$VERBOSE" = true ]; then
  echo "Changed shell files detected:"
  printf '  %s\n' "${SHELL_FILES[@]}"
  echo ""
  echo "Running ShellCheck..."
  echo ""
fi

# Run ShellCheck
SHELLCHECK_OUTPUT=$(mktemp)

set +e
shellcheck -x "${SHELL_FILES[@]}" > "$SHELLCHECK_OUTPUT" 2>&1
SHELLCHECK_STATUS=$?
set -e

if [ $SHELLCHECK_STATUS -eq 0 ]; then
  rm "$SHELLCHECK_OUTPUT"
  hook_status pass
else
  cat "$SHELLCHECK_OUTPUT" >&2
  echo "" >&2
  rm "$SHELLCHECK_OUTPUT"
  hook_status fail
fi
