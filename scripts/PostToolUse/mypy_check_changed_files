#!/bin/bash
# shellcheck source-path=SCRIPTDIR
# Script to run mypy type checker on changed Python files
# Usage:
#   - As Claude Code hook: receives JSON via STDIN
#   - Direct invocation: mypy_check_changed_files [-v|--verbose] [file1 file2 ...]
#
# See ../../docs/hook_interface.md for interface specification and exit code behavior

set -e
HOOK_NAME="mypy"
FILE_PATTERN='\.py$'
SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPTS_DIR/hook_common.bash"

# Check if file exists
for file in $CHANGED_FILES; do
  if [ ! -f "$file" ]; then
    hook_status na "file not found"
  fi
done

# Determine mypy command - prefer uv run, then direct command
if command -v uv &> /dev/null; then
  MYPY_CMD="uv run --quiet --with mypy mypy"
elif command -v mypy &> /dev/null; then
  MYPY_CMD="mypy"
else
  hook_status na "mypy not found"
fi

if [ "$VERBOSE" = true ]; then
  echo "Changed Python files detected:"
  echo "  $CHANGED_FILES"
  echo ""
  echo "Running mypy type checker..."
  echo ""
fi

# Run mypy
MYPY_OUTPUT=$(mktemp)

set +e
$MYPY_CMD --ignore-missing-imports --no-error-summary "$CHANGED_FILES" > "$MYPY_OUTPUT" 2>&1
MYPY_STATUS=$?
set -e

if [ $MYPY_STATUS -eq 0 ]; then
  if [ -s "$MYPY_OUTPUT" ]; then
    cat "$MYPY_OUTPUT"
    echo ""
  fi
  rm "$MYPY_OUTPUT"
  hook_status pass
else
  cat "$MYPY_OUTPUT" >&2
  echo "" >&2
  rm "$MYPY_OUTPUT"
  hook_status fail
fi
