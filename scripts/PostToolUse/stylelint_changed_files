#!/bin/bash
# Script to run Stylelint on changed CSS/SCSS files
# Usage:
#   - As Claude Code hook: receives JSON via STDIN
#   - Direct invocation: stylelint_changed_files [-v|--verbose] [file1 file2 ...]
#
# See ../../docs/hook_interface.md for interface specification and exit code behavior

set -e
HOOK_NAME="stylelint"
FILE_PATTERN='\.(css|scss)$'
SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPTS_DIR/hook_common.bash"

# Source nvm if available (needed for hooks which run in fresh shell)
# Deferred until after extension check to avoid ~100ms cost on non-CSS files
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  # shellcheck source=/dev/null
  source "$NVM_DIR/nvm.sh" --no-use
  if [ -f ".nvmrc" ]; then
    nvm use --silent 2>/dev/null || true
  fi
fi

# Determine Stylelint command
if [ -x "./bin/stylelint" ]; then
  STYLELINT_CMD="./bin/stylelint"
elif command -v yarn &> /dev/null; then
  STYLELINT_CMD="yarn stylelint"
else
  STYLELINT_CMD="npx stylelint"
fi

if [ "$VERBOSE" = true ]; then
  echo "Changed CSS/SCSS files detected:"
  echo "  $CHANGED_FILES"
  echo ""
  echo "Running Stylelint with auto-fix..."
  echo ""
fi

# Run Stylelint with auto-fix
STYLELINT_OUTPUT=$(mktemp)

set +e
$STYLELINT_CMD --fix "$CHANGED_FILES" > "$STYLELINT_OUTPUT" 2>&1
STYLELINT_STATUS=$?
set -e

if [ $STYLELINT_STATUS -eq 0 ]; then
  if [ -s "$STYLELINT_OUTPUT" ]; then
    cat "$STYLELINT_OUTPUT"
    echo ""
  fi
  rm "$STYLELINT_OUTPUT"
  hook_status pass
else
  cat "$STYLELINT_OUTPUT" >&2
  echo "" >&2
  rm "$STYLELINT_OUTPUT"
  hook_status fail
fi
