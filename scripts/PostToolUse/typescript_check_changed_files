#!/bin/bash
# Script to run TypeScript type checking on changed TypeScript files
# Usage:
#   - As Claude Code hook: receives JSON via STDIN
#   - Direct invocation: typescript_check_changed_files [-v|--verbose] [file1 file2 ...]
#
# See ../../docs/hook_interface.md for interface specification and exit code behavior

set -e
HOOK_NAME="tsc"
FILE_PATTERN='\.(ts|tsx)$'
SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPTS_DIR/hook_common.bash"

# Source nvm if available (needed for hooks which run in fresh shell)
# Deferred until after extension check to avoid ~100ms cost on non-TS files
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  # shellcheck source=/dev/null
  source "$NVM_DIR/nvm.sh" --no-use
  if [ -f ".nvmrc" ]; then
    nvm use --silent 2>/dev/null || true
  fi
fi

# Check if TypeScript is available
if ! command -v npm &> /dev/null; then
  hook_status na "npm not found"
fi

if [ ! -f "package.json" ]; then
  hook_status na "no package.json"
fi

if [ ! -f "tsconfig.json" ]; then
  hook_status na "no tsconfig.json"
fi

if [ "$VERBOSE" = true ]; then
  echo "Changed TypeScript files detected:"
  echo "  $CHANGED_FILES"
  echo ""
  echo "Running TypeScript type checker..."
  echo ""
fi

# Run TypeScript type checking
TSC_OUTPUT=$(mktemp)

set +e
if grep -q '"typecheck"' package.json; then
  npm run typecheck > "$TSC_OUTPUT" 2>&1
else
  npx tsc --noEmit > "$TSC_OUTPUT" 2>&1
fi
TSC_STATUS=$?
set -e

if [ $TSC_STATUS -eq 0 ]; then
  rm "$TSC_OUTPUT"
  hook_status pass
else
  cat "$TSC_OUTPUT" >&2
  echo "" >&2
  rm "$TSC_OUTPUT"
  hook_status fail
fi
