#!/bin/bash
# Script to run ESLint on changed JavaScript files
# Usage:
#   - As Claude Code hook: receives JSON via STDIN
#   - Direct invocation: eslint_changed_files [-v|--verbose] [file1 file2 ...]
#
# See ../../docs/hook_interface.md for interface specification and exit code behavior

set -e
HOOK_NAME="eslint"
FILE_PATTERN='\.(js|jsx|ts|tsx)$'
SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPTS_DIR/hook_common.bash"

# Source nvm if available (needed for hooks which run in fresh shell)
# Deferred until after extension check to avoid ~100ms cost on non-JS files
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  # shellcheck source=/dev/null
  source "$NVM_DIR/nvm.sh" --no-use
  if [ -f ".nvmrc" ]; then
    nvm use --silent 2>/dev/null || true
  fi
fi

# Determine ESLint command - prefer eslint_d (daemon, ~0.1s warm) over cold eslint (~0.8s)
# To disable eslint_d: set NO_ESLINT_D=1 or touch ./tmp/no-eslint-d
# To suppress the "not installed" hint: touch ./tmp/no-eslint-d
if command -v eslint_d &> /dev/null && [ -z "$NO_ESLINT_D" ] && [ ! -f "./tmp/no-eslint-d" ]; then
  ESLINT_CMD="eslint_d"
elif [ -f "node_modules/.bin/eslint" ]; then
  ESLINT_CMD="./node_modules/.bin/eslint"
  if ! command -v eslint_d &> /dev/null && [ ! -f "./tmp/no-eslint-d" ]; then
    echo "eslint_d is not installed. Install it to speed up linting: npm install -g eslint_d (touch ./tmp/no-eslint-d to suppress)" >&2
  fi
elif command -v yarn &> /dev/null; then
  ESLINT_CMD="yarn --silent eslint"
else
  ESLINT_CMD="npx --silent eslint"
fi

if [ "$VERBOSE" = true ]; then
  echo "Changed JavaScript files detected:"
  echo "  $CHANGED_FILES"
  echo ""
  echo "Running ESLint with auto-fix..."
  echo ""
fi

# Run ESLint with auto-fix
ESLINT_OUTPUT=$(mktemp)

set +e
$ESLINT_CMD --fix "$CHANGED_FILES" > "$ESLINT_OUTPUT" 2>&1
ESLINT_STATUS=$?
set -e

# Filter out yarn/npx wrapper noise from output
filter_yarn_noise() {
  grep -v "^yarn run" | \
  grep -v "^\\$" | \
  grep -v "^error Command failed" | \
  grep -v "^info Visit" | \
  grep -v "^Done in" | \
  sed '/^$/N;/^\n$/D'  # Remove excessive blank lines
}

if [ $ESLINT_STATUS -eq 0 ]; then
  if [ -s "$ESLINT_OUTPUT" ]; then
    cat "$ESLINT_OUTPUT" | filter_yarn_noise
    echo ""
  fi
  rm "$ESLINT_OUTPUT"
  hook_status pass
else
  cat "$ESLINT_OUTPUT" | filter_yarn_noise >&2
  echo "" >&2
  rm "$ESLINT_OUTPUT"
  hook_status fail
fi
