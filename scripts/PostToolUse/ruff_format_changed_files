#!/bin/bash
# Script to run Ruff formatter on changed Python files
# Usage:
#   - As Claude Code hook: receives JSON via STDIN
#   - Direct invocation: ruff_format_changed_files [-v|--verbose] [file1 file2 ...]
#
# Uses ruff format to auto-format Python files (replaces Black with faster Rust-based formatter).
# See ../../docs/hook_interface.md for interface specification and exit code behavior

set -e
HOOK_NAME="ruff-fmt"
FILE_PATTERN='\.py$'
SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPTS_DIR/hook_common.bash"

# Check if file exists
for file in $CHANGED_FILES; do
  if [ ! -f "$file" ]; then
    hook_status na "file not found"
  fi
done

# Determine ruff command - prefer uv run, then direct command
if command -v uv &> /dev/null && [ -f "pyproject.toml" ]; then
  RUFF_CMD="uv run ruff"
elif command -v ruff &> /dev/null; then
  RUFF_CMD="ruff"
else
  hook_status na "ruff not found"
fi

if [ "$VERBOSE" = true ]; then
  echo "Changed Python files detected:"
  echo "  $CHANGED_FILES"
  echo ""
  echo "Running Ruff formatter..."
  echo ""
fi

# Check what would change first
DIFF_OUTPUT=""
CHANGES_DETECTED=false

for file in $CHANGED_FILES; do
  if [ -f "$file" ]; then
    FORMATTED=$(mktemp)
    $RUFF_CMD format --quiet "$file" -o "$FORMATTED" 2>/dev/null || cp "$file" "$FORMATTED"

    if ! diff -q "$file" "$FORMATTED" > /dev/null 2>&1; then
      CHANGES_DETECTED=true
      FILE_DIFF=$(diff -U1 "$file" "$FORMATTED" | tail -n +3 || true)
      DIFF_OUTPUT="${DIFF_OUTPUT}${file}\n${FILE_DIFF}\n\n"
    fi

    rm "$FORMATTED"
  fi
done

if [ "$CHANGES_DETECTED" = false ]; then
  hook_status pass
fi

# Apply formatting
RUFF_OUTPUT=$(mktemp)

set +e
$RUFF_CMD format "$CHANGED_FILES" > "$RUFF_OUTPUT" 2>&1
RUFF_STATUS=$?
set -e

if [ $RUFF_STATUS -eq 0 ]; then
  echo "Ruff reformatted:"
  echo ""
  echo -e "$DIFF_OUTPUT"
  rm "$RUFF_OUTPUT"
  hook_status pass
else
  cat "$RUFF_OUTPUT" >&2
  echo "" >&2
  rm "$RUFF_OUTPUT"
  hook_status fail
fi
