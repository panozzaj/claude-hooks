#!/bin/bash
# Script to run gofmt on changed Go files
# Usage:
#   - As Claude Code hook: receives JSON via STDIN
#   - Direct invocation: gofmt_changed_files [-v|--verbose] [file1 file2 ...]
#
# See ../../docs/hook_interface.md for interface specification and exit code behavior

set -e
HOOK_NAME="gofmt"
FILE_PATTERN='\.go$'
SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPTS_DIR/hook_common.bash"

if ! command -v gofmt &> /dev/null; then
  hook_status na "gofmt not found"
fi

if [ ! -f "$CHANGED_FILES" ]; then
  hook_status na "file not found"
fi

if [ "$VERBOSE" = true ]; then
  echo "Changed Go files detected:"
  echo "  $CHANGED_FILES"
  echo ""
  echo "Running gofmt..."
  echo ""
fi

# Run gofmt -w to format in place
FMT_OUTPUT=$(mktemp)

set +e
gofmt -w "$CHANGED_FILES" > "$FMT_OUTPUT" 2>&1
FMT_STATUS=$?
set -e

if [ $FMT_STATUS -eq 0 ]; then
  if [ -s "$FMT_OUTPUT" ]; then
    cat "$FMT_OUTPUT"
    echo ""
  fi
  rm "$FMT_OUTPUT"
  hook_status pass
else
  cat "$FMT_OUTPUT" >&2
  echo "" >&2
  rm "$FMT_OUTPUT"
  hook_status fail
fi
