#!/bin/bash
# Script to run Ruff linter on changed Python files
# Usage:
#   - As Claude Code hook: receives JSON via STDIN
#   - Direct invocation: ruff_check_changed_files [-v|--verbose] [file1 file2 ...]
#
# Runs ruff check --fix to auto-fix issues where possible.
# See ../../docs/hook_interface.md for interface specification and exit code behavior

set -e
HOOK_NAME="ruff"
FILE_PATTERN='\.py$'
SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPTS_DIR/hook_common.bash"

# Check if file exists
for file in $CHANGED_FILES; do
  if [ ! -f "$file" ]; then
    hook_status na "file not found"
  fi
done

# Determine ruff command - prefer uv run, then direct command
if command -v uv &> /dev/null && [ -f "pyproject.toml" ]; then
  RUFF_CMD="uv run ruff"
elif command -v ruff &> /dev/null; then
  RUFF_CMD="ruff"
else
  hook_status na "ruff not found"
fi

if [ "$VERBOSE" = true ]; then
  echo "Changed Python files detected:"
  echo "  $CHANGED_FILES"
  echo ""
  echo "Running Ruff linter with auto-fix..."
  echo ""
fi

# Run Ruff with auto-fix
RUFF_OUTPUT=$(mktemp)

set +e
$RUFF_CMD check --fix "$CHANGED_FILES" > "$RUFF_OUTPUT" 2>&1
RUFF_STATUS=$?
set -e

if [ $RUFF_STATUS -eq 0 ]; then
  if [ -s "$RUFF_OUTPUT" ]; then
    cat "$RUFF_OUTPUT"
    echo ""
  fi
  rm "$RUFF_OUTPUT"
  hook_status pass
else
  cat "$RUFF_OUTPUT" >&2
  echo "" >&2
  rm "$RUFF_OUTPUT"
  hook_status fail
fi
