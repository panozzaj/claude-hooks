#!/bin/bash
# Stop hook: Blocks when source code is changed without any test files being touched.
#
# Purely deterministic — no LLM needed. Checks git working directory for changed
# files, classifies them as source/test/excluded, and blocks if source files changed
# without any test files being modified.
#
# Receives JSON on stdin: {session_id, transcript_path, cwd, permission_mode, hook_event_name, stop_hook_active}
# Output {"decision": "block", "reason": "..."} to force Claude to keep working.
# Exit 0 with no JSON output = approve (let Claude stop).
#
# Requires: jq, git

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
COOLDOWN="$SCRIPT_DIR/../common/cooldown"
HOOK_NAME="stop_missing_tests"

# Read JSON from stdin
if [ -t 0 ]; then
  exit 0
fi
INPUT=$(cat)

# Check stop_hook_active to avoid infinite loops
STOP_HOOK_ACTIVE=$(echo "$INPUT" | jq -r '.stop_hook_active // false')
if [ "$STOP_HOOK_ACTIVE" = "true" ]; then
  exit 0
fi

# Extract cwd and cd to it
CWD=$(echo "$INPUT" | jq -r '.cwd // empty')
if [ -z "$CWD" ] || [ ! -d "$CWD" ]; then
  exit 0
fi
cd "$CWD"

# Verify it's a git repo
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  exit 0
fi

# Get changed files (staged + unstaged + untracked)
CHANGED_FILES=$(git diff --name-only HEAD 2>/dev/null || true)
UNTRACKED=$(git ls-files --others --exclude-standard 2>/dev/null || true)
ALL_CHANGED=$(printf '%s\n%s' "$CHANGED_FILES" "$UNTRACKED" | grep -v '^$' | sort -u)

if [ -z "$ALL_CHANGED" ]; then
  exit 0
fi

# Classify files
HAS_SOURCE=false
HAS_TESTS=false
SOURCE_LIST=""

while IFS= read -r file; do
  basename=$(basename "$file")
  dir="$file"

  # --- Test file detection ---
  # Filename patterns: *_test.*, *_spec.*, *.test.*, *.spec.*, test_*.*
  if echo "$basename" | grep -qE '(_test\.|_spec\.|\.test\.|\.spec\.)'; then
    HAS_TESTS=true
    continue
  fi
  if echo "$basename" | grep -qE '^test_.*\.'; then
    HAS_TESTS=true
    continue
  fi
  # Directory patterns: spec/, test/, tests/, __tests__/
  if echo "$dir" | grep -qE '(^|/)(spec|test|tests|__tests__)/'; then
    HAS_TESTS=true
    continue
  fi

  # --- Excluded directory detection ---
  if echo "$dir" | grep -qE '(^|/)(config|scripts|bin|\.github|docker|tmp|\.playwright-mcp|node_modules)/'; then
    continue
  fi
  # Migration paths
  if echo "$dir" | grep -qE '(^|/)db/migrate/'; then
    continue
  fi
  if echo "$dir" | grep -qE '(^|/).*/migrations/'; then
    continue
  fi
  if echo "$file" | grep -qE '(^|/)db/schema\.rb$'; then
    continue
  fi

  # --- Excluded extension detection ---
  ext="${basename##*.}"
  case "$ext" in
    md|txt|yml|yaml|json|toml|lock|gitignore) continue ;;
    css|scss|sass|less) continue ;;
    html|erb|haml|slim|ejs) continue ;;
    svg|png|jpg|gif|ico) continue ;;
  esac

  # --- Source file detection ---
  case "$ext" in
    rb|py|js|ts|tsx|jsx|go|rs|java|kt|swift|c|cpp|h|scala|ex|php)
      HAS_SOURCE=true
      if [ -n "$SOURCE_LIST" ]; then
        SOURCE_LIST="$SOURCE_LIST"$'\n'"$file"
      else
        SOURCE_LIST="$file"
      fi
      ;;
  esac
done <<< "$ALL_CHANGED"

# Block only if source files changed and no test files changed
if [ "$HAS_SOURCE" = "true" ] && [ "$HAS_TESTS" = "false" ]; then
  # Check cooldown before blocking
  SESSION_ID=$(echo "$INPUT" | jq -r '.session_id // empty')
  "$COOLDOWN" check "$SESSION_ID" "$HOOK_NAME" || exit 0

  # Build file list for reason message
  FILE_COUNT=$(echo "$SOURCE_LIST" | wc -l | tr -d ' ')
  if [ "$FILE_COUNT" -le 5 ]; then
    FILE_LIST=$(echo "$SOURCE_LIST" | paste -sd', ' -)
  else
    FIRST_FILES=$(echo "$SOURCE_LIST" | head -5 | paste -sd', ' -)
    REMAINING=$((FILE_COUNT - 5))
    FILE_LIST="${FIRST_FILES} (and ${REMAINING} more)"
  fi

  REASON="[stop_missing_tests] You modified source files without adding or updating tests: ${FILE_LIST}. Please add tests for your changes."
  jq -n --arg reason "$REASON" '{"decision": "block", "reason": $reason}'
  "$COOLDOWN" record "$SESSION_ID" "$HOOK_NAME"
  exit 0
fi

# No source-only changes — let Claude stop
exit 0
