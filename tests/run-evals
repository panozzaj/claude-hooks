#!/bin/bash
# Run eval tests for Claude Code hook scripts.
#
# Evals call the real LLM (requires ollama running with gemma3:4b).
# They test prompt quality, not script plumbing.
# Separated from unit tests (run-tests) because they are slower and non-deterministic.
#
# Usage:
#   ./tests/run-evals                      # Run all evals in parallel (default)
#   ./tests/run-evals -j 2                 # Run with 2 parallel jobs
#   ./tests/run-evals --no-parallel        # Run sequentially
#   ./tests/run-evals evals/specific.bats  # Run specific eval file(s)

set -e

# Colors
GREEN='\033[0;32m'
RED='\033[0;31m'
BLUE='\033[0;34m'
YELLOW='\033[0;33m'
NC='\033[0m'

# Parse flags
JOBS=$(sysctl -n hw.logicalcpu 2>/dev/null || nproc 2>/dev/null || echo 4)
BATS_ARGS=()
FILES=()

while [ $# -gt 0 ]; do
  case "$1" in
    -j)
      JOBS="$2"
      shift 2
      ;;
    --no-parallel)
      JOBS=""
      shift
      ;;
    *)
      FILES+=("$1")
      shift
      ;;
  esac
done

# Check for GNU parallel (required by bats --jobs; moreutils parallel won't work)
has_gnu_parallel() {
  command -v parallel &>/dev/null && parallel --version 2>&1 | grep -q 'GNU parallel'
}

if [ -n "$JOBS" ]; then
  if has_gnu_parallel; then
    BATS_ARGS+=(--jobs "$JOBS")
  else
    echo -e "${YELLOW}Warning: GNU parallel not found, running sequentially${NC}"
    echo -e "${YELLOW}Install with: brew install parallel${NC}"
  fi
fi

# Change to tests directory
cd "$(dirname "$0")"

echo -e "${BLUE}Running eval tests for Claude Code hook scripts...${NC}"
echo -e "${YELLOW}These tests call the real LLM — requires ollama running with gemma3:4b${NC}"
echo ""

# Check if bats is installed
if ! command -v bats &> /dev/null; then
  echo -e "${RED}Error: bats-core is not installed${NC}"
  echo "Install it with: brew install bats-core"
  exit 1
fi

# Check if llm is available
if ! command -v llm &> /dev/null; then
  echo -e "${RED}Error: llm CLI is not installed${NC}"
  echo "Install it with: pip install llm llm-ollama"
  exit 1
fi

# Run evals
if [ ${#FILES[@]} -gt 0 ]; then
  TARGET=("${FILES[@]}")
else
  TARGET=(evals/*.bats)
fi

if bats "${BATS_ARGS[@]}" "${TARGET[@]}"; then
  echo ""
  echo -e "${GREEN}✓ All evals passed!${NC}"
  exit 0
else
  echo ""
  echo -e "${RED}✗ Some evals failed${NC}"
  exit 1
fi
